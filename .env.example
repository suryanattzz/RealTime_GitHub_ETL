# Copy this file to .env and adjust values if needed.
# PowerShell alternative: set with $env:VAR_NAME="value"

GITHUB_API_URL=https://api.github.com/events
GITHUB_TOKEN=

KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=github-events

STREAM_DURATION=600
REQUEST_INTERVAL=5
REQUEST_TIMEOUT=15
MAX_RETRIES=3
BACKOFF_FACTOR=1.0
DEDUPE_CACHE_SIZE=10000
KAFKA_SEND_TIMEOUT=10

OUTPUT_DIR=./data
BATCH_SIZE=50
